<h1>Forgot your password?</h1>

<%= tag.div(flash[:alert], style: "color:red") if flash[:alert] %>

<%= form_with url: admin_passwords_path do |form| %>
  <div>
    <%= form.label :email_address, "Admin Email Address" %>
    <%= form.email_field :email_address, required: true %>
  </div>
  <%= form.submit "Send Reset Instructions" %>
<% end %>

