<nav class="site-nav" aria-label="Primary navigation">
  <a class="site-nav__link site-nav__brand" href="#top">THE MOON RINGERS</a>
  <a class="site-nav__link" href="#music">Music</a>
  <a class="site-nav__link" href="#shows">Shows</a>
  <a class="site-nav__link" href="#misc">Misc</a>
</nav>

<main id="top" class="home-page">
  <h1>THE MOON RINGERS</h1>

  <section id="music" class="home-section">
    <h2>Music</h2>
  </section>

  <section id="shows" class="home-section">
    <h2>Shows</h2>

    <div class="shows-table-wrap">
      <table class="shows-table">
        <tbody>
          <% @shows.each do |show| %>
            <% show_time = show.time.in_time_zone("Eastern Time (US & Canada)") %>
            <tr>
              <td><%= show_time.strftime("%B %-d, %Y") %></td>
              <td><%= show_time.strftime("%-l:%M %p") %></td>
              <td><%= show.venue.name %></td>
              <td><%= "#{show.venue.city}, #{show.venue.state}" %></td>
              <td><%= show.price %></td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  </section>

  <section id="misc" class="home-section">
    <h2>Misc</h2>
  </section>
</main>
