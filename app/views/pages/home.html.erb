<nav class="site-nav" aria-label="Primary navigation">
  <a class="site-nav__link site-nav__brand" href="#top">THE MOON RINGERS</a>
  <a class="site-nav__link" href="#music">Music</a>
  <a class="site-nav__link" href="#shows">Shows</a>
  <a class="site-nav__link" href="#misc">Misc</a>
</nav>

<main id="top" class="home-page">
  <h1>THE MOON RINGERS</h1>

  <% flash.each do |type, message| %>
    <p class="flash flash--<%= type %>" role="status"><%= message %></p>
  <% end %>

  <section id="music" class="home-section">
    <h2>Music</h2>
  </section>

  <section id="shows" class="home-section">
    <h2>Shows</h2>

    <div class="shows-table-wrap">
      <table class="shows-table">
        <tbody>
          <% @shows.each do |show| %>
            <% show_time = show.time.in_time_zone("Eastern Time (US & Canada)") %>
            <tr>
              <td><%= show_time.strftime("%B %-d, %Y") %></td>
              <td><%= show_time.strftime("%-l:%M %p") %></td>
              <td>
                <% if show.venue&.map_url.present? %>
                  <%= link_to show.venue.name, show.venue.map_url %>
                <% else %>
                  <%= show.venue&.name %>
                <% end %>
              </td>
              <td><%= [show.venue&.city, show.venue&.state].compact_blank.join(", ") %></td>
              <td><%= show.price %></td>
              <td class="shows-table__links">
                <% show.links.each do |link| %>
                  <%= link_to link.name, link.url %>
                <% end %>
              </td>
              <% if admin? %>
                <td class="shows-table__edit">
                  <%= link_to "Edit", edit_admin_show_path(show), class: "form-button form-button--secondary" %>
                </td>
              <% end %>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>

    <% if admin? %>
      <%= render "pages/admin_show_form",
            form: @show_form,
            venues: @venues,
            links: @links,
            form_url: admin_shows_path,
            form_method: :post,
            title: "Add a Show",
            submit_label: "Create Show",
            error_action: "created" %>
    <% end %>
  </section>

  <section id="misc" class="home-section">
    <h2>Misc</h2>
  </section>
</main>
